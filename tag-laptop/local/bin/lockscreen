#!/bin/sh
set -e

wallpaper_dir="$HOME/pictures/wallpapers"

insidecolor=#00000000
ringcolor=#ffffffff
keyhlcolor=#d23c3dff
bshlcolor=#d23c3dff
separatorcolor=#00000000
insidevercolor=#00000000
insidewrongcolor=#d23c3dff
ringvercolor=#ffffffff
ringwrongcolor=#ffffffff
verifcolor=#ffffffff
timecolor=#ffffffff
datecolor=#ffffffff
font="sans-serif"
locktext='Type password to unlock...'

LOCK_IMAGE="$wallpaper_dir/firewatch.jpg"
UNIT_FILE=/etc/systemd/system/suspend@.service

_log_err() {
	echo "$1"
	exit 1
}

_usage() {
	echo "$(basename "$0") [ lock | install | uninstall ]"
}

_lock_i3() {
	i3lock \
		--tiling \
		--ignore-empty-password \
		--clock \
		--timestr="%H:%M" \
		--refresh-rate=60 \
		--image "$LOCK_IMAGE" \
		--timepos="x+110:h-70" \
		--datepos="x+43:h-45" \
		--clock \
		--date-align 1 \
		--datestr "$locktext" \
		--insidecolor "$insidecolor" \
		--ringcolor "$ringcolor" \
		--line-uses-inside \
		--keyhlcolor "$keyhlcolor" \
		--bshlcolor "$bshlcolor" \
		--separatorcolor "$separatorcolor" \
		--insidevercolor "$insidevercolor" \
		--insidewrongcolor "$insidewrongcolor" \
		--ringvercolor "$ringvercolor" \
		--ringwrongcolor "$ringwrongcolor" \
		--indpos "x+280:h-70" \
		--radius 20 \
		--ring-width 4 \
		--veriftext "" \
		--wrongtext "" \
		--verifcolor "$verifcolor" \
		--timecolor "$timecolor" \
		--datecolor "$datecolor" \
		--time-font "$font" \
		--date-font "$font" \
		--layout-font "$font" \
		--verif-font "$font" \
		--wrong-font "$font" \
		--noinputtext "" \
		--force-clock
}

_lock_sway() {
	swaylock \
		--ignore-empty-password \
		--show-failed-attempts \
		--daemonize \
		--image "$LOCK_IMAGE" \
		--scaling "fill" \
		--font "$font" \
		--inside-color "$insidecolor" \
		--ring-color "$ringcolor" \
		--line-uses-inside \
		--key-hl-color "$keyhlcolor" \
		--bs-hl-color "$bshlcolor" \
		--separator-color "$separatorcolor" \
		--inside-ver-color "$insidevercolor" \
		--inside-wrong-color "$insidewrongcolor" \
		--ring-ver-color "$ringvercolor" \
		--ring-wrong-color "$ringwrongcolor" \
		--indicator-radius 20 \
		--indicator-x-position "60" \
		--indicator-y-position "850" \
		--indicator-thickness "4" \
		--text-ver-color "$verifcolor"

	# TODO: find a better solution
	systemctl --user restart mako
}

_lock() {
	if [ "$SYSTEMD_LOCK" = "1" ]; then
		SWAYLOCK="$(find /run/user/1000/ -name "sway-ipc*.sock" -type s 2>/dev/null || true)"
		export SWAYLOCK
	fi
	if [ "$WAYLAND_DISPLAY" ]; then
		_lock_sway
	else
		_lock_i3
	fi
}

_install() {
	cat <<-EOF | sudo tee "$UNIT_FILE"
	[Unit]
	Description=User suspend lock
	Before=sleep.target

	[Service]
	User=%I
	Type=forking
	Environment=SYSTEMD_LOCK=1
	Environment=DISPLAY=:0
	Environment=WAYLAND_DISPLAY=wayland-0
	Environment=XDG_RUNTIME_DIR=/run/user/1000
	ExecStart=/home/%I/.local/bin/lockscreen lock

	[Install]
	WantedBy=sleep.target
	EOF

	sudo systemctl daemon-reload
	sudo systemctl enable "suspend@$USER"
}

_uninstall() {
	sudo systemctl disable "suspend@$USER"
	sudo rm "$UNIT_FILE"
	sudo systemctl daemon-reload
}

case "$1" in
	lock)
		_lock
		;;
	install)
		_install
		;;
	uninstall)
		_uninstall
		;;
	*)
		_usage
		;;
esac
