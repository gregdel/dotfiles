#!/bin/sh

_check_link() {
	[ -d "/sys/class/net/$1" ]
}

_check_wifi() {
	dev="$1"
	count="$(/usr/sbin/iwconfig "$dev" 2>/dev/null | /usr/bin/grep -c proton)"
	[ "$count" = "1" ]
}

_is_connected() {
	_check_link cscotun0 && return 0
	_check_link enx2cea7f330177 && return 0
	_check_wifi wlo1 && return 0
	return 1
}

icon=""
ret=1
if _is_connected; then
	icon=""
	ret=0
fi

echo "$icon OVH"
return $ret
