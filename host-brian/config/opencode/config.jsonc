{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "*": "ask",
        "read": "allow",
        "glob": "allow",
        "grep": "ask",
        "list": "allow",
        "lsp": "allow",
        "skill": "allow",
        "task": "allow",
        "todoread": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "bash": {
            "*": "ask",
            "fd *": "allow",
            "rg *": "allow",
            "git status*": "allow",
            "git log*": "allow",
            "git diff*": "allow",
            "git show*": "allow",
            "git rev-parse*": "allow",
            "git ls-files*": "allow",
            "git remote -v*": "allow",
        },
    },
}
