#!/bin/sh
# shellcheck disable=3043

_output_state() {
	local name="$1"
	swaymsg -t get_outputs | jq --arg name "$name" \
		'.[] | select(.name == $name) | .active'
}

_toggle() {
	local cmd=""
	case "$active" in
		true)  cmd="disable" ;;
		false) cmd="enable"  ;;
	esac
	swaymsg output "$monitor" "$cmd"
}

_icon() {
	local icon="󰍹"
	[ "$monitor" = "DP-1" ] && icon=""
	[ "$active" = "false" ] && icon="󰍶"
	printf '%s' "$icon"
}

monitor="$1"
[ -n "$monitor" ] || exit 1
shift
active=$(_output_state "$monitor")

case "$1" in
	toggle) _toggle ;;
	*)      _icon   ;;
esac
