# vim: ft=sh :

_start_agent() {
	local pid
	pid=$(pgrep -u "$USER" 'ssh-agent' | head -n 1)
	if [ -z "$pid" ]; then
		# Start the ssh-agent
		eval "$(ssh-agent -s)" >/dev/null
		return 0
	fi
	SSH_AGENT_PID=$pid

	sock=$(find \
		"$HOME/.ssh/agent" /tmp \
		-maxdepth 2 \
		-type s \
		-user "$USER" \
		-name '*agent.*' \
		-print -quit \
		2>/dev/null)
	[ -n "$sock" ] && SSH_AUTH_SOCK=$sock

	export SSH_AUTH_SOCK
	export SSH_AGENT_PID
}
_start_agent

agent() {
	local key
	local timeout=10800 # 3h
	if [ -f ~/.ssh/id_ed25519 ]; then
		key=~/.ssh/id_ed25519
	else
		key=~/.ssh/id_rsa
	fi
	ssh-add -t "$timeout" "$key"
}

killagent() {
	pgrep -u "$USER" ssh-agent | xargs kill
	_start_agent
}
