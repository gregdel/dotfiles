# vim: ft=sh :

_agent_dir=$HOME/.ssh/agent
_agent_env=$_agent_dir/env

_start_agent() {
	if [ -r "$_agent_env" ]; then
		# shellcheck disable=1090
		. "$_agent_env"
		if [ -n "$SSH_AUTH_SOCK" ]; then
			ssh-add -l >/dev/null 2>&1; [ $? -le 1 ] && return 0
		fi
	fi

	mkdir -p "$_agent_dir"
	eval "$(ssh-agent -s)" >/dev/null
	{
		printf 'SSH_AUTH_SOCK=%s; export SSH_AUTH_SOCK\n' "$SSH_AUTH_SOCK"
		printf 'SSH_AGENT_PID=%s; export SSH_AGENT_PID\n' "$SSH_AGENT_PID"
	} >"$_agent_env"
}
_start_agent

agent() {
	local timeout=10800 # 3h
	ssh-add -t "$timeout"
}

killagent() {
	# shellcheck disable=1090
	[ -r "$_agent_env" ]    && . "$_agent_env"
	[ -n "$SSH_AGENT_PID" ] && ssh-agent -k >/dev/null
	rm -f "$_agent_env"
}
